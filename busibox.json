{
  "$schema": "https://busibox.io/schemas/app-manifest-v1.json",
  "name": "Busibox App Template Demo",
  "id": "busibox-template-demo",
  "version": "1.0.0",
  "description": "Demo application showcasing Busibox SSO authentication, database operations, and agent API calls. Includes deletable demo features for testing deployment.",
  "icon": "Boxes",
  "defaultPath": "/myapp",
  "defaultPort": 3002,
  "healthEndpoint": "/api/health",
  "buildCommand": "npm run build",
  "startCommand": "npm start",
  "appMode": "prisma",
  "database": {
    "required": true,
    "preferredName": "app_template_demo",
    "schemaManagement": "prisma",
    "seedCommand": "npm run db:seed"
  },
  "requiredEnvVars": [],
  "optionalEnvVars": [
    "NEXT_PUBLIC_DEBUG",
    "DEMO_AGENT_API_URL"
  ],
  "busiboxAppVersion": "^2.1.17"
}

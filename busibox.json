{
  "$schema": "https://busibox.io/schemas/app-manifest-v1.json",
  "name": "Busibox App Template",
  "id": "app-template",
  "version": "1.0.0",
  "description": "Template for building Busibox-compatible applications",
  "icon": "Boxes",
  "defaultPath": "/myapp",
  "defaultPort": 3002,
  "healthEndpoint": "/api/health",
  "buildCommand": "npm run build",
  "startCommand": "npm start",
  "appMode": "prisma",
  "database": {
    "required": false,
    "preferredName": "myapp",
    "schemaManagement": "prisma",
    "seedCommand": "npm run db:seed"
  },
  "requiredEnvVars": [],
  "optionalEnvVars": [
    "NEXT_PUBLIC_DEBUG"
  ],
  "busiboxAppVersion": "^2.1.17"
}

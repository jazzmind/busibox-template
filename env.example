# =============================================================================
# BUSIBOX APP TEMPLATE - ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local for local development:
#   cp env.example .env.local
#
# For Busibox deployments, environment variables are automatically
# generated from Ansible vault - DO NOT use this file for those deployments.

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Node environment
NODE_ENV=development

# App name (used for token audience validation and cookies)
APP_NAME=my-app

# Port for local dev server
PORT=3002

# Base path for routing (if behind nginx proxy)
# For nginx proxy at /myapp: set to /myapp
# For direct access: leave empty
NEXT_PUBLIC_BASE_PATH=

# App URL (for redirects and links)
NEXT_PUBLIC_APP_URL=http://localhost:3002

# =============================================================================
# OPERATIONAL MODE
# =============================================================================
# Choose your app's operational mode:
#   - frontend: API proxy pattern (no direct database access)
#   - prisma: Direct database access via Prisma ORM

APP_MODE=frontend

# =============================================================================
# AUTHENTICATION (Required)
# =============================================================================

# AI Portal URL (where users authenticate)
# Local:         http://localhost:3000
# Proxmox Prod:  http://10.96.200.201:3000
# Proxmox Stage: http://10.96.201.201:3000
NEXT_PUBLIC_AI_PORTAL_URL=http://localhost:3000

# AuthZ Service (for token exchange)
# Local Docker:  http://localhost:8010
# Proxmox Prod:  http://10.96.200.210:8010
# Proxmox Stage: http://10.96.201.210:8010
AUTHZ_BASE_URL=http://localhost:8010

# OAuth client credentials (register with AuthZ service)
AUTHZ_CLIENT_ID=my-app
AUTHZ_CLIENT_SECRET=local-dev-secret

# =============================================================================
# FRONTEND-ONLY MODE (APP_MODE=frontend)
# =============================================================================

# Backend API URL (where to proxy requests)
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8000

# Default API audience for token exchange
# Use data-api when your app stores data via data-api (see lib/data-api-client.ts)
DEFAULT_API_AUDIENCE=backend-api

# Data API URL (for apps using data-api for structured storage)
# Local Docker:  http://localhost:8002
# Proxmox:       http://data-api:8002
DATA_API_URL=http://localhost:8002

# =============================================================================
# PRISMA MODE (APP_MODE=prisma)
# =============================================================================

# Database URL (PostgreSQL)
# Local Docker:  postgresql://user:pass@localhost:5432/myapp
# Proxmox:       postgresql://user:pass@pg-lxc:5432/myapp
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myapp

# =============================================================================
# OPTIONAL: LOCAL DEVELOPMENT
# =============================================================================

# Test session JWT (for local development without AI Portal)
# Get this from AuthZ service after authentication
# TEST_SESSION_JWT=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...

# Enable verbose authz logging
VERBOSE_AUTHZ_LOGGING=false

# Skip TLS verification for self-signed certs
# WARNING: NEVER use this in production!
# NODE_TLS_REJECT_UNAUTHORIZED=0

# =============================================================================
# OPTIONAL: DEBUGGING
# =============================================================================

# Enable debug logging
DEBUG=false

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# OPTION 1: Frontend-Only Mode (Recommended for most apps)
# --------------------------------------------------------
# 1. Copy this file:
#    cp env.example .env.local
#
# 2. Set APP_MODE=frontend
#
# 3. Configure NEXT_PUBLIC_BACKEND_API_URL to your backend
#
# 4. Start development server:
#    npm run dev
#
#
# OPTION 2: Prisma Mode (Direct database access)
# -----------------------------------------------
# 1. Copy this file:
#    cp env.example .env.local
#
# 2. Set APP_MODE=prisma
#
# 3. Configure DATABASE_URL
#
# 4. Push schema to database:
#    npm run db:push
#
# 5. Generate Prisma client:
#    npm run db:generate
#
# 6. Start development server:
#    npm run dev
#
#
# BUSIBOX DEPLOYMENT
# ------------------
# For Busibox deployments, DO NOT use this file.
# Environment variables are generated from Ansible vault.
# See: busibox/provision/ansible/group_vars/all/apps.yml
